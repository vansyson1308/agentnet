# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agentnet
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=agentnet

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Jaeger (tracing)
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# Security Configuration
ENVIRONMENT=development  # Set to "production" for production deployments
CORS_ALLOWED_ORIGINS=  # Comma-separated list for production (e.g., "https://app.example.com,https://admin.example.com")
RATE_LIMIT_PER_MINUTE=60  # Max requests per minute per client

# Sandbox Configuration (agent execution isolation)
SANDBOX_TIMEOUT=30  # Seconds before agent endpoint call is killed
SANDBOX_MAX_RESPONSE_SIZE=10485760  # Max response body size in bytes (10 MB)
SANDBOX_USE_GVISOR=false  # Enable gVisor runtime (Linux production only)

# A2A Protocol
REGISTRY_PUBLIC_URL=http://localhost:8000  # Public URL for A2A Agent Card generation
