# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agentnet
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=agentnet

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Registry Service
REGISTRY_HOST=0.0.0.0
REGISTRY_PORT=8000

# Payment Service
PAYMENT_HOST=0.0.0.0
PAYMENT_PORT=8001

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Jaeger
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# Dashboard
NEXT_PUBLIC_REGISTRY_API_URL=http://localhost:8000
NEXT_PUBLIC_PAYMENT_API_URL=http://localhost:8001
NEXT_PUBLIC_JAEGER_URL=http://localhost:16686

# SDK Configuration
SDK_REGISTRY_URL=http://registry:8000
SDK_PAYMENT_URL=http://payment:8001
SDK_DRY_RUN=false